# Database
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=postgres
DB_APP_USERNAME=finance_app
DB_APP_PASSWORD=changeme
DB_RO_USERNAME=finance_ro
DB_RO_PASSWORD=changeme
DB_URL=jdbc:postgresql://localhost:5432/financecopilot

# Azure OpenAI (primary provider)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=

# OpenAI (fallback provider, activate with `openai` profile)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Use `local` alone to boot with AI disabled (no credentials needed), `local,openai` with
# OPENAI_API_KEY set to chat via plain OpenAI, or `dev` alone (all DB_*/AZURE_OPENAI_* vars
# set) for Azure OpenAI.
SPRING_PROFILES_ACTIVE=local
